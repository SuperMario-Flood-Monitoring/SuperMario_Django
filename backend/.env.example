APP_ENV=local
DJANGO_SECRET_KEY=replace-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true
SUPERMARIO_PUBLIC_BASE_URL=http://127.0.0.1:5173
SUPERMARIO_API_BASE_URL=http://127.0.0.1:8000/api
SUPERMARIO_LLM_BASE_URL=http://127.0.0.1:8001/llm
SUPERMARIO_LLM_ANALYZE_URL=http://127.0.0.1:8001/llm/analyze
TELEGRAM_BOT_TOKEN=
SUPERMARIO_JWT_SECRET_KEY=change-me
SUPERMARIO_REFRESH_COOKIE_SAMESITE=Lax
SUPERMARIO_REFRESH_COOKIE_SECURE=false
SUPERMARIO_INITIAL_ADMIN_USERNAME=admin
SUPERMARIO_INITIAL_ADMIN_PASSWORD=supermario4
SUPERMARIO_RISK_POLICY_LEVEL=balanced
SUPERMARIO_RISK_CONTEXT_LEVEL=optimal
SUPERMARIO_RISK_PAUSE_ON_TRIGGER=false
SUPERMARIO_RISK_EXPORT_CONTEXT_ON_TRIGGER=false
# SUPERMARIO_RISK_CONTEXT_EXPORT_DIR=/absolute/path/to/risk-context-exports

# 로컬 Python 단독 실행 fallback은 SQLite를 사용할 수 있다.
DATABASE_ENGINE=sqlite
SQLITE_PATH=db.sqlite3

# Docker Compose와 운영 환경은 PostgreSQL을 사용한다.
# 로컬 Docker에서는 .env 값이 없으면 docker-compose.yml이 POSTGRES_PASSWORD를
# supermario_local_password로 기본 지정한다.
# 이 로컬 비밀번호를 운영 환경에서 재사용하지 않는다.
POSTGRES_DB=supermario
POSTGRES_USER=supermario
POSTGRES_PASSWORD=change-this-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432
